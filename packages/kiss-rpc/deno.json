{
  "name": "@kissjs/rpc",
  "version": "0.2.1",
  "exports": {
    ".": "./src/index.ts"
  },
  "imports": {
    "lit": "npm:lit@^3"
  },
  "tasks": {
    "build": "deno run -A npm:vite build --config vite.config.build.ts",
    "dev": "deno run -A npm:vite build --config vite.config.build.ts --watch"
  },
  "compilerOptions": {
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
